<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    android:foreground="?attr/selectableItemBackground">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- Badges HD / LIVE -->
        <TextView
            android:id="@+id/badge_live"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:text="VIVO"
            android:textSize="9sp"
            android:textColor="#fff"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_live"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/badge_hd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_toStartOf="@id/badge_live"
            android:layout_marginEnd="3dp"
            android:text="HD"
            android:textSize="9sp"
            android:textColor="#000"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_hd"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />

        <!-- Logo del canal -->
        <FrameLayout
            android:id="@+id/logo_container"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_logo_placeholder">

            <ImageView
                android:id="@+id/image_logo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/text_initial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="22sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />
        </FrameLayout>

        <!-- Nombre del canal -->
        <TextView
            android:id="@+id/text_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/logo_container"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed" />
    </RelativeLayout>

</androidx.cardview.widget.CardView>
