<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila superior: competición + hora + live -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/image_flag"
                android:layout_width="20dp"
                android:layout_height="14dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/text_competition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_live"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="● EN VIVO"
                android:textSize="10sp"
                android:textColor="#fff"
                app:chipBackgroundColor="@color/live"
                app:chipMinHeight="24dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <!-- Fila de equipos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Local -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/image_home"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_shield_placeholder" />

                <TextView
                    android:id="@+id/text_home"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:maxLines="2" />
            </LinearLayout>

            <!-- VS -->
            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="VS"
                android:gravity="center"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <!-- Visitante -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical|end">

                <TextView
                    android:id="@+id/text_away"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="end"
                    android:maxLines="2" />

                <ImageView
                    android:id="@+id/image_away"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_shield_placeholder" />
            </LinearLayout>
        </LinearLayout>

        <!-- Chips de canales -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_channels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/text_no_channels"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin canal disponible"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
